.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.detail-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-section {
  color: white;
}

.date-day {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
}

.date-month {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.date-week {
  font-size: 24rpx;
  opacity: 0.7;
}

.subject-badge {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.badge-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.card-body {
  padding: 30rpx;
}

.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.info-value.duration {
  font-weight: bold;
  color: #4CAF50;
  font-size: 32rpx;
}

.info-value.content {
  line-height: 1.6;
  white-space: pre-wrap;
}

.edit-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.subject-options, .duration-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.subject-option, .duration-option {
  padding: 15rpx 30rpx;
  border-radius: 30rpx;
  border: 2rpx solid #ddd;
  font-size: 26rpx;
}

.subject-option.active, .duration-option.active {
  background: #f0f9f0;
  border-color: #4CAF50;
  color: #4CAF50;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  flex: 1;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 25rpx;
  border-radius: 12rpx;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #666;
}

.edit-btn .btn-text {
  color: #4CAF50;
}

.delete-btn .btn-text {
  color: #E53935;
}

.cancel-btn {
  background: #f5f5f5;
}

.cancel-btn .btn-text {
  color: #666;
}

.confirm-btn {
  background: #4CAF50;
}

.confirm-btn .btn-text {
  color: white;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 550rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.delete-modal {
  padding: 40rpx;
  text-align: center;
}

.delete-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.delete-message {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

.delete-actions {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  padding: 25rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.btn-danger {
  background: #E53935;
  color: white;
}
